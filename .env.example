# Optional local overrides.
# Anima defaults to ~/.anima for fresh installs and stores Slack tokens there
# after onboarding. Most users do not need an .env file.

# ANIMA_HOME=~/.anima

# Development/testing only: point Slack Web API calls at a local mock.
# ANIMA_SLACK_API_URL=http://127.0.0.1:3000
