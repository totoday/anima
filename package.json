{
  "name": "@meetquinn/anima",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "description": "An AI agent team that works alongside your human team in Slack.",
  "homepage": "https://github.com/MeetQuinn/anima#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MeetQuinn/anima.git"
  },
  "bugs": {
    "url": "https://github.com/MeetQuinn/anima/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.0.0",
  "type": "module",
  "bin": {
    "anima": "bin/anima",
    "animactl": "bin/animactl"
  },
  "files": [
    "CLAUDE.md",
    ".env.example",
    "README.md",
    "agent.config.example.json",
    "bin/",
    "config.example.json",
    "dist/server/",
    "dist/shared/",
    "dist/web/",
    "docs/design.md",
    "docs/deployment.md",
    "docs/quickstart.md",
    "docs/release.md",
    "docs/runtime-providers.md",
    "docs/service-runbook.md",
    "templates/",
    "examples/"
  ],
  "scripts": {
    "build": "rm -rf dist packages/animactl/dist && tsc -p tsconfig.json && pnpm build:ui && node scripts/prepare-animactl-package.mjs",
    "build:server": "rm -rf dist/server dist/shared && tsc -p tsconfig.json",
    "prepare": "husky",
    "lint": "pnpm --dir web lint",
    "type-check": "tsc -p tsconfig.json --noEmit && cd web && npx tsc -b --dry",
    "build:ui": "cd web && pnpm build",
    "pack:check": "pnpm build && npm pack --dry-run --ignore-scripts",
    "pack:tarball": "rm -f meetquinn-anima-*.tgz anima-*.tgz && npm pack",
    "prepack": "pnpm build",
    "services:restart": "pnpm build && node dist/server/cli/animactl.js services restart",
    "services:start": "node dist/server/cli/animactl.js services start",
    "services:status": "node dist/server/cli/animactl.js services status",
    "services:stop": "node dist/server/cli/animactl.js services stop",
    "dev:services:restart": "pnpm build && ANIMA_HOME=./.anima node dist/server/cli/animactl.js services restart",
    "dev:services:start": "ANIMA_HOME=./.anima node dist/server/cli/animactl.js services start",
    "dev:services:status": "ANIMA_HOME=./.anima node dist/server/cli/animactl.js services status",
    "dev:services:stop": "ANIMA_HOME=./.anima node dist/server/cli/animactl.js services stop",
    "test": "pnpm test:fast",
    "test:fast": "pnpm build:server && node scripts/run-tests.mjs fast",
    "test:fast:dist": "node scripts/run-tests.mjs fast",
    "test:unit": "pnpm build:server && node scripts/run-tests.mjs unit",
    "test:api": "pnpm build:server && node scripts/run-tests.mjs api",
    "test:runtime": "pnpm build:server && node scripts/run-tests.mjs runtime",
    "test:all": "pnpm build && node scripts/run-tests.mjs all",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0"
  },
  "dependencies": {
    "@slack/bolt": "^4.7.2",
    "@slack/web-api": "^7.15.2",
    "commander": "^14.0.3",
    "fastify": "^5.8.5",
    "ignore": "^7.0.5",
    "luxon": "^3.7.2",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "web/**/*.{ts,tsx}": [
      "pnpm --dir web exec eslint --fix"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  }
}
